# ===========================================
# FAST-TRANS-MAROC (FTM)
# Configuration Environment - EXEMPLE UNIQUEMENT
# ===========================================
# Ce fichier est un TEMPLATE - ne contient pas de vraies valeurs
# Pour utiliser : cp .env.example .env
# Puis remplissez .env avec vos vraies valeurs
# IMPORTANT : .env est ignoré par Git (voir .gitignore)
# ===========================================

# ===========================================
# Configuration Supabase
# ===========================================
# URL de votre projet Supabase
# Trouvez-la dans : app.supabase.com > Settings > API > Project URL
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anonyme publique (safe côté client)
# Trouvez-la dans : app.supabase.com > Settings > API > anon/public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ===========================================
# Environment
# ===========================================
NODE_ENV=development

# ===========================================
# Notes importantes
# ===========================================
# - Ne jamais mettre SERVICE_ROLE_KEY ici
# - Les clés secrètes sont dans GitHub Secrets
#   (Settings > Secrets and variables > Actions)
# - Codespaces : les secrets sont injectés automatiquement
# ===========================================
